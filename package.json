{
  "name": "nexus-ide",
  "version": "0.1.0",
  "description": "AI-powered desktop IDE — Monaco Editor, multi-LLM, streaming",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3,node-pty",
    "rebuild:install": "npm install --ignore-optional && npm run rebuild",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/diff-match-patch": "^1.0.36",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "diff-match-patch": "^1.0.5",
    "express": "^4.18.3",
    "monaco-editor": "^0.45.0",
    "openai": "^4.104.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.4.3",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.nexuside.app",
    "productName": "NexusIDE",
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**"
    ]
  }
}
